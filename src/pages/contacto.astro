---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title="Contacto — Cristálida Ediciones" description="Ponte en contacto con Cristálida Ediciones." />
	</head>
	<body>
		<Header />
		<main>
			<div class="page-header">
				<h1>Contacto</h1>
			</div>

			<div class="contact-grid">
				<div class="contact-info">
					<p>
						Estamos disponibles en <a href="mailto:cristalidaediciones@gmail.com">cristalidaediciones@gmail.com</a> para consultas sobre pedidos, prensa, talleres y el premio.
					</p>
					<p>
						Librerías, escuelas y bibliotecas son bienvenidas a escribirnos directamente. Realizamos envíos a cualquier parte del mundo. En Quebec, nuestros libros se encuentran en la Librería Las Américas de Montreal.
					</p>
				</div>

				<form class="contact-form" netlify name="contacto" method="POST">
					<input type="hidden" name="form-name" value="contacto" />
					<div class="field">
						<label for="nombre">Nombre</label>
						<input type="text" id="nombre" name="nombre" required />
					</div>
					<div class="field">
						<label for="email">Correo electrónico</label>
						<input type="email" id="email" name="email" required />
					</div>
					<div class="field">
						<label for="asunto">Asunto</label>
						<input type="text" id="asunto" name="asunto" />
					</div>
					<div class="field">
						<label for="mensaje">Mensaje</label>
						<textarea id="mensaje" name="mensaje" rows="6" required></textarea>
					</div>
					<button type="submit" class="btn-submit">Enviar mensaje</button>
				</form>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	.page-header {
		margin-bottom: 3rem;
		border-bottom: 1px solid rgba(61, 43, 107, 0.12);
		padding-bottom: 2rem;
	}
	.lead { font-size: 1.2rem; color: var(--color-muted); margin: 0; }
	.contact-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 4rem;
		align-items: start;
	}
	.contact-info h2 { font-size: 1.4rem; margin-top: 2rem; }
	.contact-info h2:first-child { margin-top: 0; }
	.email a {
		font-family: var(--font-heading);
		font-size: 1.2rem;
		color: var(--color-secondary);
	}
	.location { color: var(--color-muted); font-size: 0.9rem; }

	.contact-form { display: flex; flex-direction: column; gap: 1.25rem; }
	.field { display: flex; flex-direction: column; gap: 0.4rem; }
	label { font-size: 0.9rem; font-weight: 600; color: var(--color-primary); }
	input, textarea {
		padding: 0.6rem 0.9rem;
		border: 1.5px solid rgba(61, 43, 107, 0.2);
		border-radius: 4px;
		font-family: var(--font-body);
		font-size: 1rem;
		color: var(--color-text);
		background: white;
		transition: border-color 0.2s;
	}
	input:focus, textarea:focus {
		outline: none;
		border-color: var(--color-secondary);
	}
	.btn-submit {
		background: var(--color-primary);
		color: white;
		border: none;
		padding: 0.8rem 2rem;
		border-radius: 4px;
		font-size: 1rem;
		font-family: var(--font-body);
		font-weight: 600;
		cursor: pointer;
		transition: background 0.2s;
		align-self: flex-start;
	}
	.btn-submit:hover { background: var(--color-secondary); }

	@media (max-width: 720px) {
		.contact-grid { grid-template-columns: 1fr; gap: 2rem; }
	}
</style>
