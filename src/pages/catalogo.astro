	{ title: "Edificio Cuba", author: "Arístides Vega Chapú", year: 2022, genre: "Poesía", amazonUrl: A+"2925321143", cover: P+"edificio-cuba-aristides-vega-chapu-cubierta.webp" },
	{ title: "Tu roto olor de feria encaminada", author: "Pedro Péglez González", year: 2022, genre: "Poesía", amazonUrl: A+"292532116X", cover: P+"tu-roto-olor-de-feia-encaminada-pedro-peglez-cubierta-del-digital.webp" },
	{ title: "Indagación de la sombra", author: "Yandrey Lay", year: 2022, genre: "Poesía", amazonUrl: A+"2925321003", cover: P+"indagacion-de-la-sombra-yandrey-lay-cubierta-del-digital.webp" },
	{ title: "Música de fondo", author: "Carmen Amelia del Cristo", year: 2022, genre: "Poesía", amazonUrl: A+"B09ZDZT248", cover: P+"musica-de-fondo-carmen-amelia-del-cristo-cubierta.webp" },
	{ title: "Sola como avara sobre su montaña de oro", author: "María Liliana Celorrio", year: 2022, genre: "Poesía", amazonUrl: A+"B09WLDQB2J", cover: P+"sola-como-avara-sobre-su-montana-de-oro-maria-liliana-celorrio-cubierta.webp" },
	{ title: "La campana en el abismo", author: "Roberto Manzano", year: 2022, genre: "Roberto Manzano", amazonUrl: A+"B09SXGPC7V", cover: P+"la-campana-en-el-abismo-roberto-manzano-cubierta.webp" },
	{ title: "El hombre cotidiano", author: "Roberto Manzano", year: 2022, genre: "Roberto Manzano", amazonUrl: A+"B09TDSFXY9", cover: P+"el-hombre-cotidiano-roberto-manzano-cubierta.webp" },
	{ title: "Rapsodia de vivir", author: "Roberto Manzano", year: 2022, genre: "Roberto Manzano", amazonUrl: A+"B09WLYKM3H", cover: P+"rapsodia-de-vivir-roberto-manzano-cubierta.webp" },
	{ title: "Defensa de la poesía", author: "Roberto Manzano", year: 2022, genre: "Roberto Manzano", amazonUrl: A+"B09YVJRJTS", cover: P+"defensa-de-la-poesia-roberto-manzano-cubierta.webp" },
	{ title: "La hilacha y otras transfiguraciones", author: "Roberto Manzano", year: 2022, genre: "Roberto Manzano", amazonUrl: A+"B09TMYWDJ2", cover: P+"la-hilacha-y-otras-transfiguraciones-roberto-manzano-cubierta.webp" },
	{ title: "Puerta al camino", author: "Roberto Manzano", year: 2022, genre: "Roberto Manzano", amazonUrl: A+"B09XRS5KX4", cover: P+"puerta-al-camino-roberto-manzano-cubierta.webp" },
	{ title: "Lo que escriben mis ojos", author: "Benita López Peñate", year: 2022, genre: "Poesía", amazonUrl: A+"B09XJQ9J52", cover: P+"lo-que-escriben-mis-ojos-benita-lopez-penate-cubierta.webp" },
	{ title: "Crónicas domésticas", author: "Ana Núñez González", year: 2022, genre: "Narrativa", amazonUrl: A+"B09S5ZNBM8", cover: P+"cronicas-domesticas-ana-nunez-gonzalez-cubierta.webp" },
	{ title: "Canciones eslavas", author: "Jesús Lozada Guevara", year: 2022, genre: "Poesía", amazonUrl: A+"B09XZMCNGW", cover: P+"canciones-eslavas-jesus-lozada-guevara-cubierta.webp" },
	// 2021
	{ title: "Pensamientos libres", author: "Roberto Manzano", year: 2021, genre: "Roberto Manzano", amazonUrl: A+"B09PKDLK2T", cover: P+"pensamientos-libres-roberto-manzano-cubierta.webp" },
].sort((a, b) => b.year - a.year);

const generos = ["Todos", "Roberto Manzano", "Poesía", "Narrativa", "Álbum ilustrado", "Infantil"];
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title="Catálogo — Cristálida Ediciones" description="Todos los libros publicados por Cristálida Ediciones. Poesía, narrativa, ensayo e infantil." />
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "ItemList",
			"name": "Catálogo de Cristálida Ediciones",
			"itemListElement": libros
				.filter(l => l.amazonUrl && l.amazonUrl !== "https://www.amazon.ca/dp/")
				.map((l, i) => ({
					"@type": "ListItem",
					"position": i + 1,
					"item": {
						"@type": "Book",
						"name": l.title,
						"author": {
							"@type": "Person",
							"name": l.author
						},
						"publisher": {
							"@type": "Organization",
							"name": "Cristálida Ediciones"
						},
						"inLanguage": "es",
						"url": l.amazonUrl,
						"genre": l.genre
					}
				}))
		})} />
	</head>
	<body>
		<Header />
		<main>
			<div class="page-header">
				<h1>Catálogo</h1>
				<p class="lead">Todos los títulos publicados por Cristálida Ediciones.</p>
			</div>

			<!-- Filtro por género -->
			<div class="filtros" id="filtros">
				{generos.map(g => (
					<button class={`filtro-btn ${g === 'Todos' ? 'active' : ''}`} data-genre={g}>{g}</button>
				))}
			</div>

			<!-- Banner descarga catálogo infantil -->
			<div class="banner-infantil" id="banner-infantil" style="display:none">
				<div class="banner-infantil-inner">
					<div>
						<p class="banner-titulo">📚 Catálogo de Literatura Infantil y Juvenil · 2026</p>
						<p class="banner-desc">Una colección para lectores que sueñan. Álbumes ilustrados y narrativa juvenil.</p>
					</div>
					<a href="/catalogo-literatura-infantil-cristalida-ediciones-2026.pdf" download class="btn-descarga">
						Descargar catálogo PDF
					</a>
				</div>
			</div>

			<!-- Grid de libros -->
			<div class="books-grid" id="books-grid">
				{libros.map(libro => (
					<article
						class="book-card"
						data-genre={libro.genre}
						data-square={libro.square ? "true" : "false"}
						itemscope
						itemtype="https://schema.org/Book"
					>
						<meta itemprop="name" content={libro.title} />
						<meta itemprop="author" content={libro.author} />
						<meta itemprop="datePublished" content={String(libro.year)} />
						<meta itemprop="genre" content={libro.genre} />
						{libro.amazonUrl !== '#' && <link itemprop="url" href={libro.amazonUrl} />}

						<a href={libro.amazonUrl} target="_blank" rel="noopener" class="cover-link">
							{libro.cover
								? <img src={libro.cover} alt={`Portada de ${libro.title}`} class="book-cover" itemprop="image" loading="lazy" />
								: <div class="book-cover-placeholder"><span>{libro.title[0]}</span></div>
							}
						</a>
						<div class="book-info">
							<span class="book-genre">{libro.genre}</span>
							<h2 class="book-title" itemprop="name">{libro.title}</h2>
							<p class="book-author" itemprop="author">{libro.author}</p>
							<p class="book-year">{libro.year}</p>
							{libro.amazonUrl !== '#' && (
								<a href={libro.amazonUrl} target="_blank" rel="noopener" class="btn-amazon">
									Comprar en Amazon →
								</a>
							)}
						</div>
					</article>
				))}
			</div>
		</main>
		<Footer />
	</body>
</html>

<script>
	const btns = document.querySelectorAll<HTMLButtonElement>('.filtro-btn');
	const cards = document.querySelectorAll<HTMLElement>('.book-card');

	const banner = document.getElementById('banner-infantil');

	btns.forEach(btn => {
		btn.addEventListener('click', () => {
			btns.forEach(b => b.classList.remove('active'));
			btn.classList.add('active');
			const genre = btn.dataset.genre;
			cards.forEach(card => {
				const show = genre === 'Todos' || card.dataset.genre === genre;
				card.style.display = show ? '' : 'none';
			});
			if (banner) banner.style.display = genre === 'Infantil' ? 'block' : 'none';
		});
	});
</script>

<style>
	.page-header { margin-bottom: 2rem; border-bottom: 1px solid rgba(61,43,107,0.12); padding-bottom: 2rem; }
	.lead { font-size: 1.15rem; color: var(--color-muted); margin: 0; }

	.filtros { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 2.5rem; }
	.filtro-btn {
		padding: 0.4rem 1.2rem;
		border: 1.5px solid rgba(61,43,107,0.25);
		border-radius: 20px;
		background: white;
		color: var(--color-text);
		font-family: var(--font-body);
		font-size: 0.9rem;
		cursor: pointer;
		transition: all 0.2s;
	}
	.filtro-btn:hover, .filtro-btn.active {
		background: var(--color-primary);
		border-color: var(--color-primary);
		color: white;
	}

	.banner-infantil {
		margin-bottom: 2rem;
	}
	.banner-infantil-inner {
		background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
		border-radius: 8px;
		padding: 1.5rem 2rem;
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1.5rem;
		flex-wrap: wrap;
	}
	.banner-titulo {
		color: white;
		font-family: var(--font-heading);
		font-size: 1.1rem;
		font-weight: 600;
		margin: 0 0 0.25rem;
	}
	.banner-desc {
		color: rgba(255,255,255,0.8);
		font-size: 0.9rem;
		margin: 0;
	}
	.btn-descarga {
		background: var(--color-accent);
		color: var(--color-primary);
		padding: 0.65rem 1.5rem;
		border-radius: 4px;
		font-weight: 700;
		font-size: 0.9rem;
		white-space: nowrap;
		transition: background 0.2s;
		display: inline-block;
	}
	.btn-descarga:hover { background: #e0bc5a; color: var(--color-primary); }

	.books-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(190px, 1fr));
		gap: 2rem;
	}
	.book-card {
		background: white;
		border-radius: 8px;
		overflow: hidden;
		box-shadow: var(--box-shadow);
		transition: transform 0.2s, box-shadow 0.2s;
	}
	.book-card:hover { transform: translateY(-4px); box-shadow: 0 8px 24px rgba(61,43,107,0.18); }
	.cover-link { display: block; }
	.book-cover { width: 100%; aspect-ratio: 2/3; object-fit: cover; }
	[data-genre="Álbum ilustrado"] .book-cover { aspect-ratio: 1/1; }
	[data-genre="Álbum ilustrado"] .book-cover-placeholder { aspect-ratio: 1/1; }
	[data-square="true"] .book-cover { aspect-ratio: 1/1; }
	[data-square="true"] .book-cover-placeholder { aspect-ratio: 1/1; }
	.book-cover-placeholder {
		width: 100%; aspect-ratio: 2/3;
		background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
		display: flex; align-items: center; justify-content: center;
	}
	.book-cover-placeholder span { font-family: var(--font-heading); font-size: 4rem; color: rgba(255,255,255,0.2); }
	.book-info { padding: 1rem; }
	.book-genre { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-accent); font-weight: 700; }
	.book-title { font-size: 1rem; margin: 0.2rem 0; color: var(--color-primary); }
	.book-author { color: var(--color-secondary); font-size: 0.85rem; font-weight: 600; margin: 0 0 0.1rem; }
	.book-year { color: var(--color-muted); font-size: 0.8rem; margin: 0 0 0.75rem; }
	.btn-amazon { font-size: 0.8rem; font-weight: 600; color: var(--color-secondary); }
	.btn-amazon:hover { color: var(--color-accent); }
</style>
