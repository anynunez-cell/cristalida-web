---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BookCard from '../components/BookCard.astro';

const libros = [
	{
		title: "Título del libro",
		author: "Nombre del autor",
		year: 2024,
		excerpt: "Breve descripción del libro o fragmento poético que invite a la lectura.",
	},
];
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title="Catálogo — Cristálida Ediciones" description="Todos los libros publicados por Cristálida Ediciones." />
	</head>
	<body>
		<Header />
		<main>
			<div class="page-header">
				<h1>Catálogo</h1>
				<p class="lead">Todos los libros que hemos publicado hasta hoy.</p>
			</div>
			<div class="books-grid">
				{libros.map(libro => <BookCard {...libro} />)}
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	.page-header {
		margin-bottom: 3rem;
		border-bottom: 1px solid rgba(61, 43, 107, 0.12);
		padding-bottom: 2rem;
	}
	.lead {
		font-size: 1.2rem;
		color: var(--color-muted);
		margin: 0;
	}
	.books-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
		gap: 2rem;
	}
</style>
