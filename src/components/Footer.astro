---
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<div class="footer-brand">
			<p class="footer-title">Cristálida Ediciones</p>
			<p class="footer-tagline">Editorial de poesía · Quebec, Canadá</p>
		</div>
		<nav class="footer-nav">
			<a href="/catalogo">Catálogo</a>
			<a href="/autores">Autores</a>
			<a href="/premio">Premio</a>
			<a href="/formacion">Formación</a>
			<a href="/blog">Blog</a>
			<a href="/contacto">Contacto</a>
		</nav>
	</div>
	<div class="footer-bottom">
		<p>&copy; {today.getFullYear()} Cristálida Ediciones. Todos los derechos reservados.</p>
	</div>
</footer>

<style>
	footer {
		background: var(--color-primary);
		color: rgba(250, 248, 255, 0.75);
		margin-top: 4rem;
	}
	.footer-inner {
		max-width: var(--max-width);
		margin: 0 auto;
		padding: 3rem 2rem 2rem;
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		gap: 2rem;
		flex-wrap: wrap;
	}
	.footer-title {
		font-family: var(--font-heading);
		font-size: 1.4rem;
		color: var(--color-bg);
		margin: 0 0 0.25rem;
	}
	.footer-tagline {
		margin: 0;
		font-size: 0.9rem;
	}
	.footer-nav {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem 1.5rem;
	}
	.footer-nav a {
		color: rgba(250, 248, 255, 0.75);
		font-size: 0.95rem;
		transition: color 0.2s;
	}
	.footer-nav a:hover { color: var(--color-accent); }
	.footer-bottom {
		border-top: 1px solid rgba(255,255,255,0.1);
		text-align: center;
		padding: 1rem 2rem;
		font-size: 0.85rem;
	}
	.footer-bottom p { margin: 0; }
</style>
